@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="container mt-5">

    @if (ViewData["Mensaje"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-auto" style="max-width: 500px;" role="alert">
            <i class="bi bi-exclamation-circle-fill"></i> @ViewData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.EstaLogueado)
    {
        @if (!Model.Registrando && !Model.CompletandoDatos)
        {
            @* --- VISTA 1: INICIAR SESIÓN --- *@
            <div class="card shadow-sm mx-auto" style="max-width: 450px;">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-shield-lock"></i> Iniciar Sesión</h4>
                </div>
                <div class="card-body p-4">
                    <form method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Usuario / Email:</label>
                            <input type="email" asp-for="@Model.Email" class="form-control" placeholder="nombre@correo.com" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Contraseña:</label>
                            <input type="password" asp-for="@Model.Contraseña" class="form-control" placeholder="••••••••" />
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <button type="submit" asp-page-handler="BtClean" class="btn btn-secondary" style="width: 45%;">
                                <i class="bi bi-eraser"></i> Limpiar
                            </button>
                            <button type="submit" asp-page-handler="BtEnter" class="btn btn-primary" style="width: 45%;">
                                <i class="bi bi-box-arrow-in-right"></i> Entrar
                            </button>
                        </div>
                        <hr />
                        <div class="text-center">
                            <p class="mb-0 text-muted">¿No tienes una cuenta aún?</p>
                            <button type="submit" asp-page-handler="BtIrARegistro" class="btn btn-link fw-bold p-0 text-decoration-none">Regístrate aquí</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else if (Model.Registrando && !Model.CompletandoDatos)
        {
            @* --- VISTA 2: REGISTRO DATOS BÁSICOS --- *@
            <div class="card shadow-sm mx-auto" style="max-width: 500px;">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-person-plus"></i> Crear una Cuenta Nueva</h4>
                </div>
                <div class="card-body p-4">
                    <form method="POST">
                        <input type="hidden" asp-for="Registrando" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre Completo:</label>
                            <input type="text" asp-for="@Model.NombreCompleto" class="form-control" placeholder="Ej: Diego Zapata" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Cédula de Ciudadanía:</label>
                            <input type="text" asp-for="@Model.Cedula" class="form-control" placeholder="Ej: 10234567" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Fecha de Nacimiento:</label>
                            <input type="date" asp-for="@Model.FechaNacimiento" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo Electrónico:</label>
                            <input type="email" asp-for="@Model.Email" class="form-control" placeholder="ejemplo@correo.com" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Contraseña de Acceso:</label>
                            <input type="password" asp-for="@Model.Contraseña" class="form-control" placeholder="Mínimo 6 caracteres" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-success">Deseo registrarme como:</label>
                            <select asp-for="@Model.TipoRegistro" class="form-select fw-bold border-success" required>
                                <option value="">-- Selecciona tu Perfil --</option>
                                <option value="Cliente">Cliente (Quiero hacer pedidos)</option>
                                <option value="Repartidor">Repartidor (Quiero entregar domicilios)</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between pt-2 border-top">
                            <button type="submit" asp-page-handler="BtCancelarRegistro" class="btn btn-secondary" style="width: 45%;" formnovalidate>
                                <i class="bi bi-arrow-left-circle"></i> Regresar
                            </button>
                            <button type="submit" asp-page-handler="BtConfirmarRegistro" class="btn btn-success" style="width: 45%;">
                                <i class="bi bi-arrow-right-circle"></i> Siguiente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else if (Model.CompletandoDatos)
        {
            @* --- VISTA 3: DATOS ADICIONALES ESPECÍFICOS SEGÚN MODELO --- *@
            <div class="card shadow-sm mx-auto" style="max-width: 500px;">
                <div class="card-header bg-info text-dark text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-file-earmark-medical"></i> Datos Adicionales de @Model.TipoRegistro</h4>
                </div>
                <div class="card-body p-4">
                    <form method="POST">
                        @* Mantenemos en el DOM los datos anteriores en inputs ocultos para no perderlos en el PostBack *@
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="Contraseña" />
                        <input type="hidden" asp-for="NombreCompleto" />
                        <input type="hidden" asp-for="Cedula" />
                        <input type="hidden" asp-for="FechaNacimiento" />
                        <input type="hidden" asp-for="TipoRegistro" />
                        <input type="hidden" asp-for="CompletandoDatos" />

                        @if (Model.TipoRegistro == "Cliente")
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Dirección de Residencia (Direccion):</label>
                                <input type="text" asp-for="@Model.Direccion" class="form-control" placeholder="Ej: Calle 45 #12-34" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Teléfono de Contacto (Telefono):</label>
                                <input type="text" asp-for="@Model.Telefono" class="form-control" placeholder="Ej: 3001234567" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">ID Método de Pago Favorito:</label>
                                <input type="number" asp-for="@Model.MetodoPagoFav" class="form-control" required />
                            </div>
                        }
                        else if (Model.TipoRegistro == "Repartidor")
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">ID del Vehículo Asignado (VehiculoId):</label>
                                <input type="number" asp-for="@Model.VehiculoId" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">ID de la Zona Operacional (ZonaId):</label>
                                <input type="number" asp-for="@Model.ZonaId" class="form-control" required />
                            </div>
                        }

                        <div class="d-flex justify-content-between pt-2 border-top">
                            <button type="submit" asp-page-handler="BtCancelarRegistro" class="btn btn-secondary" style="width: 45%;" formnovalidate>
                                <i class="bi bi-x-circle"></i> Cancelar
                            </button>
                            <button type="submit" asp-page-handler="BtFinalizarRegistro" class="btn btn-primary" style="width: 45%;">
                                <i class="bi bi-check-lg"></i> Finalizar Registro
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        @* --- VISTA 4: USUARIO LOGUEADO CON MENÚ DINÁMICO SEGÚN ROL --- *@
        <div class="card shadow mx-auto" style="max-width: 650px;">
            <div class="card-header bg-dark text-white text-center py-3">
                <h3 class="mb-0">
                    <i class="bi bi-person-circle text-warning me-2"></i>
                    ¡Bienvenido, @(string.IsNullOrEmpty(HttpContext.Session.GetString("NombreUsuario")) ? "Usuario" : HttpContext.Session.GetString("NombreUsuario"))!
                </h3>
            </div>

            <div class="card-body p-4">
                <p class="text-muted text-center small mb-4">
                    Has iniciado sesión como: <strong class="text-primary">@HttpContext.Session.GetString("Usuario")</strong>
                </p>

                <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-list-stars text-secondary"></i> Opciones</h5>

                @if (HttpContext.Session.GetInt32("Rol") == 1)
                {
                    <div class="alert alert-danger d-flex align-items-center mb-3 py-2 small" role="alert">
                        <i class="bi bi-shield-lock-fill me-2"></i> Perfil de Administrador del Sistema
                    </div>
                    <div class="row g-2 mb-4">
                        <div class="col-md-6"><a asp-page="/Ventanas/Pedidos" class="btn btn-outline-dark w-100 text-start"><i class="bi bi-bag-check-fill me-2 text-danger"></i> Gestionar Pedidos</a></div>
                        <div class="col-md-6"><a asp-page="/Ventanas/Usuarios" class="btn btn-outline-dark w-100 text-start"><i class="bi bi-people-fill me-2 text-danger"></i> Gestionar Usuarios</a></div>
                        <div class="col-md-6"><a asp-page="/Ventanas/Pagos" class="btn btn-outline-dark w-100 text-start"><i class="bi bi-cash-coin me-2 text-danger"></i> Gestionar Pagos</a></div>
                        <div class="col-md-6"><a asp-page="/Ventanas/Facturas" class="btn btn-outline-dark w-100 text-start"><i class="bi bi-receipt me-2 text-danger"></i> Gestionar Facturas</a></div>
                        <div class="col-md-6"><a asp-page="/Ventanas/MetodoPago" class="btn btn-outline-dark w-100 text-start"><i class="bi bi-credit-card-fill me-2 text-danger"></i> Métodos de Pago</a></div>
                        <div class="col-md-6"><a asp-page="/Ventanas/Vehiculos" class="btn btn-outline-dark w-100 text-start"><i class="bi bi-car-front-fill me-2 text-danger"></i> Gestionar Vehículos</a></div>
                        <div class="col-md-6"><a asp-page="/Ventanas/Zonas" class="btn btn-outline-dark w-100 text-start"><i class="bi bi-map-fill me-2 text-danger"></i> Zonas</a></div>
                        <div class="col-md-6"><a asp-page="/Ventanas/RastreoPedido" class="btn btn-outline-dark w-100 text-start"><i class="bi bi-map-fill me-2 text-danger"></i> Ubicacion Pedidos</a></div>
                        <div class="col-md-6"><a asp-page="/Ventanas/RastreoRepartidor" class="btn btn-outline-dark w-100 text-start"><i class="bi bi-map-fill me-2 text-danger"></i> Ubicacion Repartidores</a></div>
                        <div class="col-md-6"><a asp-page="/Ventanas/Historicos" class="btn btn-dark w-100 text-start text-info"><i class="bi bi-clock-history me-2"></i> Ver históricos</a></div>
                    </div>
                }

                else if (HttpContext.Session.GetInt32("Rol") == 2)
                {
                    <div class="alert alert-success d-flex align-items-center mb-3 py-2 small" role="alert">
                        <i class="bi bi-bag-heart-fill me-2"></i> Panel de Servicios al Cliente
                    </div>
                    <div class="list-group mb-4 shadow-sm">
                        <a asp-page="/Ventanas/Productos" class="list-group-item list-group-item-action py-3"><i class="bi bi-journal-text text-success me-3"></i> <strong>Ir al menú</strong></a>
                        <a asp-page="/Ventanas/Pedidos" class="list-group-item list-group-item-action py-3"><i class="bi bi-cart-plus-fill text-success me-3"></i> <strong>Realizar pedido</strong></a>
                        <a asp-page="/Ventanas/Perfil" class="list-group-item list-group-item-action py-3 list-group-item-success"><i class="bi bi-person-bounding-box text-success me-3"></i> <strong>Mi Perfil de Usuario</strong></a>
                    </div>
                }

                else if (HttpContext.Session.GetInt32("Rol") == 3)
                {
                    <div class="alert alert-warning d-flex align-items-center mb-3 py-2 small text-dark" role="alert">
                        <i class="bi bi-truck me-2"></i> Módulo Operativo de Reparto
                    </div>
                    <div class="list-group mb-4 shadow-sm">
                        <a asp-page="/Ventanas/Pedidos" class="list-group-item list-group-item-action py-3 list-group-item-warning fw-bold text-dark"><i class="bi bi-list-stars me-3"></i> Ver Pedidos Asignados</a>
                        <a asp-page="/Ventanas/RutaEntrega" class="list-group-item list-group-item-action py-3"><i class="bi bi-geo-alt-fill text-warning me-3"></i> Ruta de entrega</a>
                        <a asp-page="/Ventanas/Perfil" class="list-group-item list-group-item-action py-3"><i class="bi bi-person-gear text-secondary me-3"></i> Perfil Operativo</a>
                    </div>
                }

                <div class="text-center border-top pt-3 mt-2">
                    <form method="POST">
                        <button type="submit" asp-page-handler="BtClose" class="btn btn-danger px-4">
                            <i class="bi bi-box-arrow-right me-1"></i> Cerrar Sesión
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>