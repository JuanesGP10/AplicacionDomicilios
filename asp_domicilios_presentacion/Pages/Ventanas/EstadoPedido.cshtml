@page
@model asp_domicilios_presentacion.Pages.Ventanas.EstadoPedidoModel
@{
    ViewData["Title"] = "Estados de Pedido";
}

<div class="container mt-4">
    <h2>Estados de Pedidos del Sistema</h2>
    <hr />

    @if (ViewData["Mensaje"] != null)
    {
        <div class="alert alert-danger">@ViewData["Mensaje"]</div>
    }

    <form method="post">
        <div class="mb-3">
            <button type="submit" asp-page-handler="BtRefrescar" class="btn btn-secondary">Refrescar</button>
        </div>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th style="width: 15%">ID Estado</th>
                    <th style="width: 35%">Nombre del Estado</th>
                    <th style="width: 50%">Descripción</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Lista != null && Model.Lista.Count > 0)
                {
                    foreach (var item in Model.Lista)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><span class="badge bg-info text-dark">@item.Nombre</span></td>
                            <td>@item.Descripcion</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center">No hay registros de estados de pedido.</td>
                    </tr>
                }
            </tbody>
        </table>
    </form>
</div>
