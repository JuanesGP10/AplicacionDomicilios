@page
@model asp_domicilios_presentacion.Pages.Ventanas.ClientesModel
@{
    ViewData["Title"] = "Gestión de Clientes";
    int rolUsuario = HttpContext.Session.GetInt32("Rol") ?? 0;
}

<div class="container mt-4">
    <h2>Gestión de Clientes</h2>
    <hr />

    @if (ViewData["Mensaje"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @ViewData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Lista != null)
    {
        <div class="mb-3">
            <form method="post">
                @if (rolUsuario == 1)
                {
                    <button type="submit" asp-page-handler="BtNuevo" class="btn btn-primary">Nuevo Registro</button>
                }
                <button type="submit" asp-page-handler="BtRefrescar" class="btn btn-secondary">Refrescar</button>
            </form>
        </div>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Fecha Nacimiento</th>
                    <th>Email</th>
                    @if (rolUsuario == 1)
                    {
                        <th>Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Lista)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nombre</td>
                        <td>@item.Cedula</td>
                        <td>@item.FechaNacimiento.ToString("dd/MM/yyyy")</td>
                        <td>@item.Email</td>
                        @if (rolUsuario == 1)
                        {
                            <td>
                                <form method="post">
                                    <button type="submit" asp-page-handler="BtModificar" asp-route-data="@item.Id" class="btn btn-sm btn-warning">Editar</button>
                                    <button type="submit" asp-page-handler="BtBorrarVal" asp-route-data="@item.Id" class="btn btn-sm btn-danger">Borrar</button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (Model.Cliente != null)
    {
        <div class="card mx-auto" style="max-width: 500px;">
            <div class="card-header">
                <h5>@(Model.Borrando ? "Eliminar Cliente" : (Model.Cliente.Id == 0 ? "Nuevo Cliente" : "Modificar Cliente"))</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Cliente.Id" />
                    <input type="hidden" asp-for="Borrando" />

                    <div class="form-group mb-3">
                        <label class="form-label">Nombre Completo</label>
                        <input type="text" asp-for="Cliente.Nombre" class="form-control" readonly="@Model.Borrando" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Cédula</label>
                        <input type="text" asp-for="Cliente.Cedula" class="form-control" readonly="@Model.Borrando" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Fecha de Nacimiento</label>
                        <input type="date" asp-for="Cliente.FechaNacimiento" class="form-control" readonly="@Model.Borrando" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Correo Electrónico</label>
                        <input type="email" asp-for="Cliente.Email" class="form-control" readonly="@Model.Borrando" required />
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label">Contrasena</label>
                        <input type="text" asp-for="Cliente.Contrasena" class="form-control" readonly="@Model.Borrando" required />
                    </div>

                    <div class="text-end">
                        <button type="submit" asp-page-handler="BtCerrar" class="btn btn-secondary">Cancelar</button>
                        @if (Model.Borrando)
                        {
                            <button type="submit" asp-page-handler="BtBorrar" class="btn btn-danger">Confirmar Borrado</button>
                        }
                        else
                        {
                            <button type="submit" asp-page-handler="BtGuardar" class="btn btn-success">Guardar</button>
                        }
                    </div>
                </form>
            </div>
        </div>
    }
</div>
