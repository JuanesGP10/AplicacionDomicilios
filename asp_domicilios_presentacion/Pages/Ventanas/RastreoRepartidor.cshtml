@page
@model asp_domicilios_presentacion.Pages.Ventanas.RastreoRepartidorModel
@{
    ViewData["Title"] = "Rastreo de Repartidores";
    int rolUsuario = HttpContext.Session.GetInt32("Rol") ?? 0;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-person-badge-fill text-danger"></i> Ubicación de Repartidores</h2>
    </div>
    <hr />

    @if (ViewData["Mensaje"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @ViewData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Lista != null)
    {
        <div class="mb-3 text-end">
            <form method="post">
                <button type="submit" asp-page-handler="BtRefrescar" class="btn btn-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Refrescar
                </button>
            </form>
        </div>

        <div class="table-responsive card shadow-sm">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead class="table-dark">
                    <tr>
                        <th>ID Registro</th>
                        <th>ID Repartidor</th>
                        <th>Estado de Ruta</th>
                        <th>Último Reporte Satelital</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Lista.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-info-circle"></i> No hay repartidores en ruta asignados en este momento.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Lista)
                    {
                        <tr>
                            <td><strong>#@item.Id</strong></td>
                            <td><span class="badge bg-dark">Domiciliario #@item.RepartidorId</span></td>
                            <td>
                                @if (rolUsuario == 1)
                                {
                                    <span class="text-danger fw-bold">Monitoreo General</span>
                                }
                                @if (rolUsuario == 3)
                                {
                                    <span class="text-warning fw-bold">Mi Ubicación Activa</span>
                                }
                                @if (rolUsuario == 2)
                                {
                                    <span class="text-success">Repartidor de mi Pedido</span>
                                }
                            </td>
                            <td>@item.FechaActualizacion.ToString("dd/MM/yyyy hh:mm tt")</td>
                            <td class="text-center">
                                <form method="post">
                                    <button type="submit" asp-page-handler="BtVerDetalle" asp-route-data="@item.Id" class="btn btn-sm btn-danger px-3">
                                        Ubicar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

@if (Model.Rastreo != null)
{
        <div class="card shadow border-0 mx-auto" style="max-width: 600px;">
            <div class="card-header bg-danger text-white py-3">
                <h5 class="mb-0 text-center fw-bold"><i class="bi bi-map-fill me-2"></i> Ubicación en el Mapa</h5>
            </div>
            <div class="card-body p-4 bg-light">
                <div class="text-center mb-3">
                    <h5 class="mt-2 fw-bold text-dark">Monitoreo en Tiempo Real</h5>
                    <p class="text-muted small mb-0">Sincronizado: @Model.Rastreo.FechaActualizacion.ToString("dd/MM/yyyy hh:mm:ss tt")</p>
                </div>

                <div class="row g-3 bg-white p-2 rounded border mb-3 shadow-sm text-center">
                    <div class="col-6 border-end">
                        <span class="text-muted small d-block fw-bold text-uppercase">Latitud</span>
                        <span class="fw-bold text-danger">@Model.Rastreo.Latitud</span>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small d-block fw-bold text-uppercase">Longitud</span>
                        <span class="fw-bold text-danger">@Model.Rastreo.Longitud</span>
                    </div>
                </div>

                <div class="card border shadow-sm overflow-hidden mb-3">
                    @if (Model.Rastreo.Latitud != 0 && Model.Rastreo.Longitud != 0)
                    {

                        string lat = Model.Rastreo.Latitud.ToString(System.Globalization.CultureInfo.InvariantCulture);
                        string lng = Model.Rastreo.Longitud.ToString(System.Globalization.CultureInfo.InvariantCulture);

                        string urlMapa = $"https://maps.google.com/maps?q={lat},{lng}&z=16&output=embed";

                        <iframe src="@urlMapa"
                                width="100%"
                                height="350"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    }
                    else
                    {
                        <div class="text-center py-5 bg-white text-muted">
                            <i class="bi bi-geo-fill text-secondary fs-1"></i>
                            <p class="mt-2 mb-0">Esperando señal satelital válida del GPS...</p>
                        </div>
                    }
                </div>

                <div class="alert alert-info border-0 shadow-sm small mb-4">
                    <i class="bi bi-info-circle-fill me-2"></i> El mapa se centra de forma automática en las coordenadas que el domiciliario reporta desde su terminal móvil.
                </div>

                <div class="text-end">
                    <form method="post">
                        <button type="submit" asp-page-handler="BtCerrar" class="btn btn-secondary px-4">
                            Regresar al Listado
                        </button>
                    </form>
                </div>
            </div>
        </div>
}
