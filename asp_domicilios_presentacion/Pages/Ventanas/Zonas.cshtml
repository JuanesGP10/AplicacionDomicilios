@page
@model asp_domicilios_presentacion.Pages.Ventanas.ZonasModel
@{
    ViewData["Title"] = "Gestión de Zonas de Envío";
}

<div class="container mt-4">
    @if (ViewData["Mensaje"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill"></i> @ViewData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (ViewData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @ViewData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2><i class="bi bi-map-fill text-primary"></i> Administración de Zonas</h2>
        @if (Model.Zona == null)
        {
            <form method="post">
                <button type="submit" asp-page-handler="BtNuevo" class="btn btn-primary fw-bold">
                    <i class="bi bi-plus-circle"></i> Agregar Nueva Zona
                </button>
            </form>
        }
    </div>

    <div class="row">
        @if (Model.Zona != null)
        {
            <div class="col-md-5 mb-4">
                <div class="card shadow-sm border-@(Model.Borrando ? "danger" : (Model.Zona.Id == 0 ? "success" : "warning"))">
                    <div class="card-header bg-@(Model.Borrando ? "danger text-white" : (Model.Zona.Id == 0 ? "success text-white" : "warning text-dark")) py-3">
                        <h5 class="mb-0">
                            <i class="bi bi-pencil-square"></i>
                            @(Model.Borrando ? "Confirmar Eliminación" : (Model.Zona.Id == 0 ? "Registrar Nueva Zona" : "Modificar Zona Existente"))
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <form method="post">
                            <input type="hidden" asp-for="Zona.Id" />
                            <input type="hidden" asp-for="Borrando" />

                            <div class="mb-3">
                                <label class="form-label fw-bold">Nombre de la Zona</label>
                                <input type="text" asp-for="Zona.Nombre" class="form-control" readonly="@Model.Borrando" placeholder="Ej: Zona Norte, Centro..." required />
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Tarifa de Envío ($)</label>
                                <input type="number" step="any" asp-for="Zona.Tarifa" class="form-control" readonly="@Model.Borrando" placeholder="Ej: 5000" required />
                            </div>

                            <div class="text-end border-top pt-3">
                                <button type="submit" asp-page-handler="BtCerrar" class="btn btn-secondary" formnovalidate>Cancelar</button>

                                @if (Model.Borrando)
                                {
                                    <button type="submit" asp-page-handler="BtBorrar" class="btn btn-danger fw-bold">Eliminar Definitivamente</button>
                                }
                                else if (Model.Zona.Id == 0)
                                {
                                    <button type="submit" asp-page-handler="BtGuardar" class="btn btn-success fw-bold">Guardar</button>
                                }
                                else
                                {
                                    <button type="submit" asp-page-handler="BtModificar" class="btn btn-warning fw-bold text-dark">Modificar</button>
                                }
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }

        <div class="@(Model.Zona != null ? "col-md-7" : "col-md-12")">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-list-ul"></i> Listado de Zonas Cobertura</h5>
                    <form method="post" class="m-0">
                        <button type="submit" asp-page-handler="BtRefrescar" class="btn btn-sm btn-outline-light" title="Actualizar Datos" formnovalidate>
                            <i class="bi bi-arrow-clockwise"></i> Refrescar
                        </button>
                    </form>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0 align-middle">
                            <thead class="table-secondary">
                                <tr>
                                    <th style="width: 15%;">Código ID</th>
                                    <th style="width: 45%;">Nombre de Zona</th>
                                    <th style="width: 20%;">Tarifa Envío</th>
                                    <th style="width: 20%;" class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Lista != null && Model.Lista.Any())
                                {
                                    foreach (var item in Model.Lista)
                                    {
                                        <tr class="@(Model.Zona?.Id == item.Id ? "table-warning fw-bold" : "")">
                                            <td>@item.Id</td>
                                            <td>@item.Nombre</td>
                                            <td class="fw-bold text-success">$@item.Tarifa.ToString("N0")</td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <form method="post" class="d-inlineme-1">
                                                        <button type="submit" asp-page-handler="BtEditar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Editar zona">
                                                            <i class="bi bi-pencil"></i> Editar
                                                        </button>
                                                    </form>

                                                    <form method="post" class="d-inline">
                                                        <button type="submit" asp-page-handler="BtBorrarVal" asp-route-data="@item.Id" class="btn btn-sm btn-outline-danger" title="Borrar zona">
                                                            <i class="bi bi-trash"></i> Borrar
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">
                                            <i class="bi bi-info-circle fs-4 d-block mb-2"></i> No se encontraron zonas registradas en la base de datos.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>