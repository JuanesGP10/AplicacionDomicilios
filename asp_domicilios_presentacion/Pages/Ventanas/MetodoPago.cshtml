@page
@model asp_domicilios_presentacion.Pages.Ventanas.MetodoPagoModel
@{
    ViewData["Title"] = "Métodos de Pago";
    int rolUsuario = Model.ObtenerRolUsuario();
}

<div class="py-5">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-wallet2 me-2"></i> Métodos de Pago</h2>
            <form method="post">
                <button type="submit" asp-page-handler="BtRefrescar" class="btn btn-outline-warning text-white border-white me-2">
                    <i class="bi bi-arrow-clockwise"></i> Actualizar
                </button>
                @if (rolUsuario == 1 && Model.MetodoNuevo == null && !Model.Borrando)
                {
                    <button type="submit" asp-page-handler="BtNuevo" class="btn btn-warning fw-bold text-dark">
                        <i class="bi bi-plus-circle me-1"></i> Agregar Método
                    </button>
                }
            </form>
        </div>

        @if (ViewData["Mensaje"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model.Borrando && Model.MetodoNuevo != null)
        {
            <div class="card border-danger shadow mb-4">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-trash me-2"></i> Eliminar Pasarela de Pago</h5>
                </div>
                <div class="card-body bg-white text-dark">
                    <p class="fs-5">¿Está seguro de que desea eliminar el método de pago: <strong>@Model.MetodoNuevo.Nombre</strong>?</p>
                    <form method="post">
                        <input type="hidden" asp-for="MetodoNuevo.Id" />
                        <button type="submit" asp-page-handler="BtBorrar" class="btn btn-danger me-2">Confirmar Eliminar</button>
                        <button type="submit" asp-page-handler="BtCerrar" class="btn btn-outline-secondary">Cancelar</button>
                    </form>
                </div>
            </div>
        }

        @if (Model.MetodoNuevo != null && !Model.Borrando)
        {
            <div class="card shadow-sm border-0 rounded-3 mb-5">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i> Configuración del Método</h5>
                </div>
                <div class="card-body bg-white p-4">
                    <form method="post" asp-page-handler="BtGuardar">
                        <input type="hidden" asp-for="MetodoNuevo.Id" />

                        <div class="row text-dark">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-secondary">Nombre de la Pasarela</label>
                                <input type="text" class="form-control" asp-for="MetodoNuevo.Nombre" required placeholder="Ej: Tarjeta de Crédito, Efectivo..." />
                            </div>

                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-semibold text-secondary">% Tasa de Comisión</label>
                                <input type="number" step="0.01" class="form-control" asp-for="MetodoNuevo.Comision" required placeholder="0.00" />
                                <small class="text-muted">Ej: Ingrese 5 para una tasa del 5%</small>
                            </div>

                            <div class="col-md-3 mb-3 d-flex align-items-center justify-content-start pt-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" asp-for="MetodoNuevo.Activo" id="switchActivo">
                                    <label class="form-check-label fw-semibold text-dark" for="switchActivo">Habilitado para Clientes</label>
                                </div>
                            </div>
                        </div>

                        <div class="row text-dark">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-semibold text-secondary">Descripción / Instrucciones</label>
                                <textarea class="form-control" asp-for="MetodoNuevo.Descripcion" rows="2" placeholder="Información adicional para el proceso de pago..."></textarea>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="submit" class="btn btn-danger px-4">Guardar Configuración</button>
                            <button type="submit" asp-page-handler="BtCerrar" class="btn btn-outline-secondary px-4">Regresar</button>
                        </div>
                    </form>
                </div>
            </div>
        }

        @if (Model.ListaMetodos != null)
        {
            <div class="card shadow border-0 rounded-3">
                <div class="card-body bg-white p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-dark text-uppercase small font-weight-bold">
                                <tr>
                                    <th class="ps-4">Código</th>
                                    <th>Nombre</th>
                                    <th>Descripción</th>
                                    <th>Comisión Operativa</th>
                                    <th class="text-center">Estado</th>
                                    @if (rolUsuario == 1)
                                    {
                                        <th class="text-center">Acciones</th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="text-dark">
                                @if (Model.ListaMetodos.Count > 0)
                                {
                                    foreach (var item in Model.ListaMetodos)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-danger">#@item.Id</td>
                                            <td class="fw-bold">@item.Nombre</td>
                                            <td class="text-muted small" style="max-width: 300px;">@item.Descripcion</td>
                                            <td class="fw-semibold text-danger">@item.Comision.ToString("N2")%</td>
                                            <td class="text-center">
                                                @if (item.Activo)
                                                {
                                                    <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i> Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary px-3 py-2"><i class="bi bi-dash-circle me-1"></i> Inactivo</span>
                                                }
                                            </td>
                                            @if (rolUsuario == 1)
                                            {
                                                <td class="text-center">
                                                    <form method="post" class="d-inline">
                                                        <button type="submit" asp-page-handler="BtModificar" asp-route-data="@item.Id" class="btn btn-sm btn-outline-danger me-1">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        <button type="submit" asp-page-handler="BtBorrarVal" asp-route-data="@item.Id" class="btn btn-sm btn-outline-secondary">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="@(rolUsuario == 1 ? 6 : 5)" class="text-center py-5 text-muted">
                                            No hay métodos de pago registrados.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>