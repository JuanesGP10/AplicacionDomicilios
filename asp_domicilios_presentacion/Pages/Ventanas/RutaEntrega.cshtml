@page
@model asp_domicilios_presentacion.Pages.Ventanas.RutaEntregaModel
@{
    ViewData["Title"] = "Rutas de Entrega";
}

<div class="container mt-4">
    <h2>Gestión de Rutas de Entrega</h2>
    <hr />

    @if (ViewData["Mensaje"] != null)
    {
        <div class="alert alert-info">@ViewData["Mensaje"]</div>
    }

    @if (Model.Lista != null)
    {
        <form method="post">
            <div class="mb-3">
                @if (Model.ObtenerRolUsuario() == 1)
                {
                    <button type="submit" asp-page-handler="BtNuevo" class="btn btn-primary">Nueva Ruta</button>
                }
                <button type="submit" asp-page-handler="BtRefrescar" class="btn btn-secondary">Refrescar</button>
            </div>

            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>ID Ruta</th>
                        <th>ID Pedido</th>
                        <th>Distancia (KM)</th>
                        <th>Tiempo Estimado (Min/Hrs)</th>
                        <th>Fecha</th>
                        @if (Model.ObtenerRolUsuario() == 1)
                        {
                            <th>Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Lista.Count > 0)
                    {
                        foreach (var item in Model.Lista)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.PedidoId</td>
                                <td>@item.DistanciaKM</td>
                                <td>@item.TiempoEstimado</td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                @if (Model.ObtenerRolUsuario() == 1)
                                {
                                    <td>
                                        <button type="submit" asp-page-handler="BtModificar" asp-route-data="@item.Id" class="btn btn-sm btn-warning">Modificar</button>
                                        <button type="submit" asp-page-handler="BtBorrarVal" asp-route-data="@item.Id" class="btn btn-sm btn-danger">Borrar</button>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="@(Model.ObtenerRolUsuario() == 1 ? 6 : 5)" class="text-center">
                                No hay rutas de entrega registradas en el sistema.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </form>
    }

    @if (Model.Ruta != null && !Model.Borrando && Model.ObtenerRolUsuario() == 1)
    {
        <div class="card p-4">
            <h4>Formulario de Ruta</h4>
            <form method="post">
                @Html.HiddenFor(x => x.Ruta!.Id)

                <div class="mb-3">
                    <label class="form-label">Código del Pedido (PedidoId)</label>
                    @Html.TextBoxFor(x => x.Ruta!.PedidoId, new { @class = "form-control", @type = "number", required = "required" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Distancia en Kilómetros (DistanciaKM)</label>
                    @Html.TextBoxFor(x => x.Ruta!.DistanciaKM, new { @class = "form-control", @type = "number", @step = "0.01", required = "required" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Tiempo Estimado (TiempoEstimado)</label>
                    @Html.TextBoxFor(x => x.Ruta!.TiempoEstimado, new { @class = "form-control", @type = "number", @step = "0.01", required = "required" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Fecha de la Ruta</label>
                    @Html.TextBoxFor(x => x.Ruta!.Fecha, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", @type = "datetime-local", required = "required" })
                </div>

                <div>
                    <button type="submit" asp-page-handler="BtGuardar" class="btn btn-success">Guardar</button>
                    <button type="submit" asp-page-handler="BtCerrar" class="btn btn-secondary" formnovalidate>Cancelar</button>
                </div>
            </form>
        </div>
    }

    @if (Model.Ruta != null && Model.Borrando && Model.ObtenerRolUsuario() == 1)
    {
        <div class="card border-danger p-4">
            <h4 class="text-danger">¿Confirmas que deseas eliminar esta ruta?</h4>
            <p><strong>ID de la Ruta:</strong> @Model.Ruta.Id</p>
            <p><strong>Pedido Asociado:</strong> @Model.Ruta.PedidoId</p>
            <p><strong>Distancia:</strong> @Model.Ruta.DistanciaKM KM</p>

            <form method="post">
                @Html.HiddenFor(x => x.Ruta!.Id)
                <div>
                    <button type="submit" asp-page-handler="BtBorrar" class="btn btn-danger">Confirmar Borrar</button>
                    <button type="submit" asp-page-handler="BtCerrar" class="btn btn-secondary">Cancelar</button>
                </div>
            </form>
        </div>
    }
</div>
