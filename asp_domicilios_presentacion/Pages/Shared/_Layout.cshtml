<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Los Quesudos</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/asp_domicilios_presentacion.styles.css" asp-append-version="true" />
    <style>
        body {
            background-color: #BD0017 !important;
        }

        .navbar-mcdonalds {
            background-color: #FFC72C !important; 
            border-bottom: 4px solid #ffffff;  
        }

            .navbar-mcdonalds .navbar-brand,
            .navbar-mcdonalds .nav-link {
                color: #222222 !important;
                font-weight: bold;
            }

                .navbar-mcdonalds .nav-link:hover {
                    color: #BD0017 !important; 
                }

        .card, .table {
            background-color: #ffffff !important;
        }

        .table-responsive {
            background-color: #ffffff;
            border-radius: 8px;
            padding: 10px;
        }

        main h2 {
            color: #ffffff !important; 
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-mcdonalds box-shadow mb-4">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Los Quesudos 🍔</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Ventanas/Productos">Menu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Ventanas/Pedidos">Pedidos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Ventanas/Perfil">Perfil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Ventanas/Notificaciones">Notificaciones</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Los Quesudos
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
